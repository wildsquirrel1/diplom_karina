<Window x:Class="hotel.BookingReportWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local="clr-namespace:hotel"

        mc:Ignorable="d"

        Title="Отчёт по проживанию" Height="950" MinHeight="730" MaxHeight="1000" Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="16" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">

    <Grid Margin="0,8,0,0">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <Grid Grid.Row="0" MinHeight="72">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260" MaxWidth="560"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="24,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <TextBlock Text="Сотрудник: " FontSize="18" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="16" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="images\icon-icons (2).png" Width="56" Height="56" Margin="0,0,12,0" Opacity="0.9" VerticalAlignment="Center"/>
                <TextBlock x:Name="HeaderTitle"
                           Text="Журнал по проживанию клиентов"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="520"/>
            </StackPanel>

            <Button Grid.Column="2" Content="✕" Style="{StaticResource CloseWindowButton}" Margin="0,12,24,0" Name="exit" Click="exit_Click" VerticalAlignment="Top"/>
        </Grid>



        <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" CornerRadius="12" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="16,12" Margin="20,12,20,0">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="*" MinWidth="180"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>



                <TextBlock Grid.Column="0" Text="Отель:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Brush.TextSecondary}"/>

                <ComboBox Grid.Column="1" x:Name="hotelCB" MinWidth="200" MinHeight="40" FontSize="15" VerticalContentAlignment="Center" Margin="0,0,16,0"/>



                <TextBlock Grid.Column="2" Text="С:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.TextSecondary}"/>

                <DatePicker Grid.Column="3" x:Name="startDatePicker" Margin="0,0,12,0" MinHeight="40" FontSize="15" VerticalContentAlignment="Center"/>



                <TextBlock Grid.Column="4" Text="По:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.TextSecondary}"/>

                <DatePicker Grid.Column="5" x:Name="endDatePicker" Margin="0,0,16,0" MinHeight="40" FontSize="15" VerticalContentAlignment="Center"/>



                <Button Grid.Column="6" Content="Сформировать отчёт" Name="GenerateReport" Click="GenerateReport_Click" Padding="14,10" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>

                <Button Grid.Column="7" Content="Экспорт в Word" Name="ExportToWordB" Click="ExportToWord_Click" Padding="14,10" FontSize="15" Style="{StaticResource SuccessButton}" VerticalAlignment="Center"/>

            </Grid>

        </Border>



        <TextBlock x:Name="Title"

                   Grid.Row="2"

                   Text="Выберите отель и период, затем нажмите «Сформировать отчёт»."

                   HorizontalAlignment="Stretch"

                   TextAlignment="Center"

                   TextWrapping="Wrap"

                   FontSize="16"

                   FontWeight="SemiBold"

                   Foreground="{StaticResource Brush.TextPrimary}"

                   Margin="24,12,24,8"/>



        <DataGrid Grid.Row="3" x:Name="reportGrid" AutoGenerateColumns="False" Margin="20,0,20,8"

                  CanUserAddRows="False" IsReadOnly="True" FontSize="15" Visibility="Hidden"

                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}">

            <DataGrid.Columns>

                <DataGridTextColumn Header="№ брони" Binding="{Binding Idbook}" Width="90" MinWidth="70"/>

                <DataGridTextColumn Header="Номер комнаты" Binding="{Binding Room.Name}" Width="SizeToCells" MinWidth="100"/>

                <DataGridTextColumn Header="Ф.И.О. клиента" Binding="{Binding GuestFullName}" Width="*" MinWidth="160"/>

                <DataGridTextColumn Header="Кол-во гостей" Binding="{Binding NumOfGuests}" Width="SizeToCells" MinWidth="90"/>

                <DataGridTextColumn Header="Дата въезда" Binding="{Binding CheckInDate, StringFormat=dd.MM.yyyy}" Width="SizeToCells" MinWidth="110"/>

                <DataGridTextColumn Header="Дата выезда" Binding="{Binding DepartureDate, StringFormat=dd.MM.yyyy}" Width="SizeToCells" MinWidth="110"/>

                <DataGridTextColumn Header="Сумма оплаты" Binding="{Binding TotalAmount, StringFormat=N0}" Width="SizeToCells" MinWidth="110"/>

            </DataGrid.Columns>

        </DataGrid>



        <Label Grid.Row="3" Content="Данные не найдены" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="22" Visibility="Visible" Name="notfound" Foreground="{StaticResource Brush.TextMuted}"/>



        <TextBlock Grid.Row="4" x:Name="totalAmountLabel" HorizontalAlignment="Right" VerticalAlignment="Bottom"

                   FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0,0,24,16"/>

    </Grid>

</Window>

