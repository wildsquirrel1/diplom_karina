<UserControl x:Class="hotel.RoomControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:hotel"
             mc:Ignorable="d" 
             Width="600" Height="600"
             Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="5" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Заголовок: этаж и категория -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10">
            <TextBlock Text="Этаж номера: " Name="floorName" FontWeight="Bold" FontSize="16" Margin="10" />
            <TextBlock Text="Категория номера: " Name="categoryName" FontWeight="SemiBold" FontSize="16" Margin="10"/>
    </StackPanel>

    <!-- Фото с перелистыванием -->
    <Grid Grid.Row="1" Margin="10">
        <Image x:Name="photoDisplay" Stretch="UniformToFill" Height="500" Width="500" />
        <Button x:Name="prevBtn" Content="❮" VerticalAlignment="Center" Width="15" Click="prevBtn_Click" HorizontalAlignment="Left" Margin="5" Opacity="0.7" Background="Transparent" Foreground="White" Cursor="Hand" Visibility="Collapsed"/>
        <Button x:Name="nextBtn" Content="❯" VerticalAlignment="Center" Click="nextBtn_Click" HorizontalAlignment="Right" Margin="5" Opacity="0.7" Background="Transparent" Foreground="White" Cursor="Hand" Visibility="Collapsed"/>
    </Grid>

    <!-- Информация: номер, статус, цена -->
    <StackPanel Grid.Row="2" Margin="10">
        <TextBlock Text="Комната номер: " Name="roomName" FontWeight="Bold" FontSize="18" Foreground="Black"/>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
            <TextBlock Text="Статус:" FontSize="14" Foreground="#555"/>
            <TextBlock Text="{Binding Status.Name}" FontSize="14" Foreground="#0e79b2" Margin="5,0,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
            <TextBlock Text="Цена:" FontSize="14" Foreground="#555"/>
            <TextBlock Name="priceCategory" FontSize="14" Foreground="DarkGreen" Margin="5,0,0,0"/>
            <TextBlock Text=" руб." FontSize="14" Foreground="DarkGreen"/>
        </StackPanel>
    </StackPanel>

    
    <Button Grid.Row="2" Content="Редактировать" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,5,10,5" 
                Name="editB" Click="editB_Click" Padding="8,4" Cursor="Hand"/>
    </Grid>
</UserControl>
