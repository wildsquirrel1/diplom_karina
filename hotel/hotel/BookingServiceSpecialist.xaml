<Window x:Class="hotel.BookingServiceSpecialist"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="BookingServiceSpecialist" Height="950" MinHeight="730" MaxHeight="1000"  
        Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" 
        FontSize="16" WindowStartupLocation="CenterScreen" Icon="C:\Users\Пользователь\source\repos\hotel\hotel\images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBlock" x:Key="searchTB">
            <Style.Setters>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="DarkGray"/>
                <Setter Property="Panel.ZIndex" Value="-1"/>
                <Setter Property="Padding" Value="10 0 0 0"/>
            </Style.Setters>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="360"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="390*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Name="exit" Content="X" Width="50" Height="50" Background="#8A6DF7" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left" Click="exit_Click"/>

        <TextBlock Grid.Row="0" Text="Бронирования отеля" VerticalAlignment="Center"
                   HorizontalAlignment="Center" FontSize="30" Margin="10"/>

        <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Text="Сотрудник: " FontSize="30" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="28" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="890"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" Background="White">
                <TextBox x:Name="searchTB" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                <TextBlock x:Name="search" MaxWidth="900" FontSize="20" Text="Поиск по ФИО клиента: " Style="{StaticResource searchTB}"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="По цене:"/>

                <ComboBox Grid.Row="1" x:Name="sordCB" Margin="10"  MinWidth="100" MaxWidth="300" MinHeight="30" MaxHeight="70" SelectedIndex="0" VerticalContentAlignment="Top" SelectionChanged="sordCB_SelectionChanged">
                    <TextBlock>-</TextBlock>
                    <TextBlock>От большей к меньше</TextBlock>
                    <TextBlock>От меньшей к большей</TextBlock>
                </ComboBox>
            </Grid>

            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="По статутсу:"/>

                <ComboBox Grid.Row="1" x:Name="filterCB" Margin="10" MinWidth="100" FontSize="36" MaxWidth="260" Width="250" MinHeight="30" MaxHeight="70" VerticalContentAlignment="Top" SelectedIndex="1" SelectionChanged="filterCB_SelectionChanged" >
                    <ComboBoxItem>Все</ComboBoxItem>
                    <ComboBoxItem>Активные</ComboBoxItem>
                    <ComboBoxItem>Отмененные</ComboBoxItem>
                    <ComboBoxItem>Завершенные</ComboBoxItem>
                </ComboBox>
            </Grid>

        </Grid>

        <Image Source="C:\Users\Пользователь\source\repos\hotel\hotel\images\icon-icons (2).png" Width="80" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 2 380 0"/>

        <!--<DataGrid Margin="0 10 0 0" Grid.Row="1" x:Name="bookingsGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ брони" Binding="{Binding Idbook}" Width="80"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding Room.Name}" Width="100"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding GuestFullName}" Width="180"/>
                <DataGridTextColumn Header="Гостей" Binding="{Binding NumOfGuests}" Width="80"/>
                <DataGridTextColumn Header="Заезд" Binding="{Binding CheckInDate, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Выезд" Binding="{Binding DepartureDate, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusBookName}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=N0}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>-->

        <Grid Grid.Row="2">
            <!-- Надпись "Не найдено" -->
            <Label x:Name="notfoundLabel" Content="Бронирований не найдено" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                   FontSize="40" Foreground="Gray" Visibility="Visible"/>

            <!-- Список карточек (изначально скрыт) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="Collapsed" x:Name="scrollViewer">
                <WrapPanel x:Name="bookingList" Margin="10"/>
            </ScrollViewer>
        </Grid>


        <Button Grid.Row="3" Content="Добавить бронь" x:Name="addBookingB" Click="addBookingB_Click"
                HorizontalAlignment="Right" Margin="20" Padding="10,5"/>
    </Grid>
</Window>
