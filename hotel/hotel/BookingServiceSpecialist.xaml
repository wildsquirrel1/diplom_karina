<Window x:Class="hotel.BookingServiceSpecialist"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="BookingServiceSpecialist" Height="950" MinHeight="730" MaxHeight="1000"  
        Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" 
        FontSize="20" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="390*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Name="exit" Content="✕" Style="{StaticResource CloseWindowButton}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,10,0,0" Click="exit_Click"/>

        <TextBlock Grid.Row="0" Text="Бронирования отеля" VerticalAlignment="Center"
                   HorizontalAlignment="Center" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="10"/>

        <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,24,0" MaxWidth="520">
            <TextBlock Text="Сотрудник: " FontSize="26" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="24" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="180"/>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Brush.Surface}" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="4,2" VerticalAlignment="Center" Margin="0,0,12,0">
                <Grid>
                    <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                    <TextBlock x:Name="search" MaxWidth="900" FontSize="25" Text="Поиск по ФИО клиента: " Style="{StaticResource searchTB}"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Сортировка:"/>

                <ComboBox Grid.Row="1" x:Name="sordCB" Margin="10" MinWidth="180" MaxWidth="360" MinHeight="48" FontSize="22" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="sordCB_SelectionChanged">
                    <ComboBoxItem Content="По дате заезда"/>
                    <ComboBoxItem Content="По сумме: по убыванию"/>
                    <ComboBoxItem Content="По сумме: по возрастанию"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="По статутсу:"/>

                <ComboBox Grid.Row="1" x:Name="filterCB" Margin="10" MinWidth="200" FontSize="22" MaxWidth="360" MinHeight="48" VerticalContentAlignment="Center" SelectedIndex="5" SelectionChanged="filterCB_SelectionChanged" >
                    <ComboBoxItem>Все</ComboBoxItem>
                    <ComboBoxItem>Активные</ComboBoxItem>
                    <ComboBoxItem>Отмененные</ComboBoxItem>
                    <ComboBoxItem>Завершенные</ComboBoxItem>
                    <ComboBoxItem>Предстоящие</ComboBoxItem>
                    <ComboBoxItem>На заезд сегодня</ComboBoxItem>
                </ComboBox>
            </Grid>

        </Grid>

        <Image Source="pack://application:,,,/images/icon-icons (2).png" Width="80" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 2 380 0"/>

        <!--<DataGrid Margin="0 10 0 0" Grid.Row="1" x:Name="bookingsGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ брони" Binding="{Binding Idbook}" Width="80"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding Room.Name}" Width="100"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding GuestFullName}" Width="180"/>
                <DataGridTextColumn Header="Гостей" Binding="{Binding NumOfGuests}" Width="80"/>
                <DataGridTextColumn Header="Заезд" Binding="{Binding CheckInDate, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Выезд" Binding="{Binding DepartureDate, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusBookName}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=N0}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>-->

        <Grid Grid.Row="2">
            <!-- Надпись "Не найдено" -->
            <Label x:Name="notfoundLabel" Content="Бронирования не найдены" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                   FontSize="40" Foreground="Gray" Visibility="Visible"/>

            <!-- Список карточек (изначально скрыт) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="Collapsed" x:Name="scrollViewer">
                <WrapPanel x:Name="bookingList" Margin="10"/>
            </ScrollViewer>
        </Grid>

        <Button Grid.Row="3" Content="Клиенты" x:Name="clientsBtn" Click="clientsBtn_Click"
            HorizontalAlignment="Right" Margin="0 20 400 20" Padding="10,5"/>

        <Button Grid.Row="3"  Content="Добавить бронь" x:Name="addBookingB" Click="addBookingB_Click"
                HorizontalAlignment="Right" Margin="20" Padding="10,5"/>
    </Grid>
</Window>
