<Window x:Class="hotel.EditHotelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Редактирование" d:Height="1900" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0">
                <Image x:Name="photoDisplay" Source="{Binding Photo}" Stretch="Uniform" Height="550" />
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal">
                    <Button Content="Загрузить" Margin="0,5,5,0" Padding="8,4" Name="editPhotoB" Click="editPhotoB_Click" />
                    <Button Content="Удалить" Name="deleteB" Margin="0,5,5,0" Padding="8,4" Click="deleteB_Click" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Название:"/>
                        <TextBox x:Name="nameT" Grid.Row="1" PreviewTextInput="nameT_PreviewTextInput" IsReadOnly="True" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Номер телефона:"/>
                        <TextBox x:Name="phoneT" Grid.Row="1" KeyDown="phoneT_KeyDown" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Электронная почта:"/>
                        <TextBox x:Name="emailT" Grid.Row="1" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Главный менеджер:"/>
                        <ComboBox Grid.Row="1" Name="mainManager" />
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Адрес:"/>
                        <TextBox x:Name="address" Grid.Row="1" IsEnabled="False" />
                    </Grid>

                    <Grid Grid.Row="5" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Город:"/>
                        <TextBox x:Name="cityT" Grid.Row="1" TextChanged="cityT_TextChanged" IsEnabled="False" />
                    </Grid>

                    <Grid Grid.Row="6" Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="450"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Карта:"/>
                        <wv2:WebView2 Grid.Row="1" x:Name="YandexMapWebView"/>
                    </Grid>

                    <Button Grid.Row="7" x:Name="edit" Click="edit_Click" Margin="10" Width="250" Height="50" Content="Изменить" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="0">
            <TextBlock Text="Редактирование" VerticalAlignment="Center" HorizontalAlignment="Center" />
            <Button x:Name="back" Content="x" Height="65" Width="65" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Right" Click="back_Click" Margin="5" />
            <StackPanel Grid.Column="0" Margin="30,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="480">
                <TextBlock Text="Сотрудник: " FontSize="30" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="28" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <Image Source="images\icon-icons (2).png" VerticalAlignment="Center" Width="90" HorizontalAlignment="Center" Margin="0 0 390 0" />
        </Grid>
    </Grid>
</Window>
