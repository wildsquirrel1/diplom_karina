<UserControl x:Class="hotel.BookingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:hotel"
             mc:Ignorable="d" 
             d:DesignHeight="250" Width="350">
    <Border BorderBrush="#ddd" BorderThickness="1" CornerRadius="10" Background="White" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок: Номер брони и Статус -->
            <Grid Grid.Row="0">
                <!-- Номер брони -->
                <TextBlock x:Name="tbId" Text="Бронь №..." 
                           FontSize="18" FontWeight="Bold" Foreground="#333"
                           VerticalAlignment="Center"/>

                <!-- Статус -->
                <Border x:Name="statusBadge" HorizontalAlignment="Right" Padding="6,3" CornerRadius="4" VerticalAlignment="Center">
                    <TextBlock x:Name="tbStatus" Text="Статус" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Основная информация -->
            <StackPanel Grid.Row="1" Margin="0,10,0,10">
                <TextBlock x:Name="tbRoom" Text="Номер: ..." FontSize="16" Margin="0,2"/>
                <TextBlock x:Name="tbClient" Text="Клиент: ..." FontSize="14" Foreground="#555" Margin="0,2"/>
                <TextBlock FontSize="14" Foreground="#555" Margin="0,2">
                    <Run Text="Гостей: "/>
                    <Run x:Name="tbGuests" Text="0"/>
                </TextBlock>

                <Separator Margin="0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Заезд:" FontSize="12" Foreground="#888"/>
                        <TextBlock x:Name="tbCheckIn" Text=".." FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Выезд:" FontSize="12" Foreground="#888" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="tbCheckOut" Text=".." FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Подвал: Сумма -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="tbTotal" Text="Итого: 0 ₽" FontSize="16" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>

                <!-- КНОПКА ОТМЕНЫ -->
                <Button x:Name="btnCancel" Grid.Column="1" Content="Отменить" Width="100" Height="30" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="14" Background="#d9534f" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0" Click="btnCancel_Click"/>

            </Grid>
        </Grid>
    </Border>
</UserControl>  
