<Window x:Class="hotel.EmployeeHHMWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Сотрудники главного менеждера по отелям" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBlock" x:Key="searchTB">
            <Style.Setters>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="DarkGray"/>
                <Setter Property="Panel.ZIndex" Value="-1"/>
                <Setter Property="Padding" Value="10 0 0 0"/>
            </Style.Setters>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Сотрудники" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="48" Margin="0,20"/>

        <StackPanel Grid.Row="0" Margin="30,30,0,0" VerticalAlignment="Top">
            <TextBlock Text="Сотрудник: " FontSize="30" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="28" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Image Source="images\icon-icons (2).png" Height="100" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 350 0"/>

        <Button Grid.Row="0" Name="back" Click="back_Click" Width="65" Height="65" Content="X" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 10 20 10" />

        <!-- Панель: поиск + сортировка + фильтр -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0" Background="White">
                <TextBox x:Name="searchTB" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                <TextBlock x:Name="search" MaxWidth="900" Text="Поиск по фио: " Style="{StaticResource searchTB}"/>
            </Grid>


            <ComboBox x:Name="sortBox" Grid.Column="1" FontSize="32" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="sortBox_SelectionChanged">
                <ComboBoxItem Content="Сначала новые"/>
                <ComboBoxItem Content="От А до Я"/>
                <ComboBoxItem Content="От Я до А"/>
            </ComboBox>

            <ComboBox x:Name="filterBox" Grid.Column="2" SelectedIndex="0"
          SelectionChanged="filterBox_SelectionChanged" Margin="10,0,0,0"  FontSize="32">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Работающие"/>
                <ComboBoxItem Content="Уволенные"/>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Сотрудник не найден" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound" Grid.RowSpan="2"/>

        <StackPanel VerticalAlignment="Top" Grid.Row="2" Visibility="Collapsed" Name="stack">
            <ScrollViewer Grid.Row="2" Margin="30,10">
                <WrapPanel x:Name="employeesPanel"/>
            </ScrollViewer>
        </StackPanel>

        <Button Grid.Row="3" Name="AddButton" Content="Добавить сотрудника" FontSize="36" Padding="25,0" HorizontalAlignment="Center" Margin="0,20" Click="AddButton_Click"/>
    </Grid>
</Window>
