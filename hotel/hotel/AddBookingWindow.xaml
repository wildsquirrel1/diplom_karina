<Window x:Class="hotel.AddBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Добавление бронирования" Height="950" MinHeight="730" MaxHeight="1000"
        Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized"
        FontSize="40" WindowStartupLocation="CenterScreen"
        Icon="C:\Users\Пользователь\source\repos\hotel\hotel\images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="360"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="8*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0 10 0 0">
            <StackPanel Grid.Column="0" Margin="30,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Width="320" >
                <TextBlock Text="Сотрудник: " FontSize="20" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="20" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <!--<Button x:Name="back" Content="X" HorizontalAlignment="Right" VerticalAlignment="Top"
            Width="60" Height="60" FontSize="40" Click="back_Click" Margin="0,20,20,0"/>-->
            <TextBlock Text="Оформление бронирования" HorizontalAlignment="Center" VerticalAlignment="Center"
               FontSize="48"/>
            <Image Source="C:\Users\Пользователь\source\repos\hotel\hotel\images\icon-icons (2).png" VerticalAlignment="Center" Margin="0 0 700 0" HorizontalAlignment="Center" Width="90"/>
        </Grid>
        <Grid Grid.Row="1" Margin="5 10 5 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="10 0">
                <Grid Margin="0 0 0 10">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Клиент:" />
                    <ComboBox x:Name="clientCB" Grid.Row="1" SelectionChanged="clientCB_SelectionChanged"/>
                    <Button Content="Новый клиент" Grid.Row="2" HorizontalAlignment="Left" Click="newClient_Click" />
                </Grid>

                <Grid Margin="0 0 0 10">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Гости:" Margin="0,0,0,10"/>
                    <ComboBox x:Name="guestsCB" Grid.Row="1"/>
                    <Button Content="Добавить гостя" Grid.Row="2" Click="addGuest_Click"/>
                    <DataGrid Grid.Row="3" x:Name="guestsDG" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Height="200" Margin="0,25">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding  FullName}"/>
                            <DataGridTextColumn Header="Документ" Binding="{Binding Document}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10 0">
                <Grid Margin="0 0 0 10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Номер:"/>
                    <ComboBox x:Name="roomCB" Grid.Row="1" SelectionChanged="roomCB_SelectionChanged"/>
                </Grid>

                <Grid Margin="0 0 0 10">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Заезд:" />
                    <DatePicker x:Name="checkInDP" Grid.Row="1" SelectedDateChanged="DateChanged"/>
                </Grid>

                <Grid Margin="0 0 0 10">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выезд:"/>
                    <DatePicker x:Name="checkOutDP" Grid.Row="1" SelectedDateChanged="DateChanged"/>
                </Grid>

                <!--<TextBlock Text="Услуги:" Margin="0,30,0,10"/>
        <StackPanel Orientation="Horizontal">
            <ListBox x:Name="servicesLB" Width="300" Height="150"/>
            <Button Content="→" Margin="20,0" Click="addService_Click"/>
            <ListBox x:Name="selectedServicesLB" Width="300" Height="150"/>
        </StackPanel>-->
            </StackPanel>
        </Grid>
        <TextBlock Grid.Row="3" x:Name="costTB" Text="Стоимость: 0 руб." FontSize="36" FontWeight="Bold" Margin="0,0,0,30"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Click="cancel_Click" Margin="0,0,30,0"/>
                <Button Content="Создать бронь" Click="createBooking_Click"/>
            </StackPanel>
    </Grid>
</Window>
