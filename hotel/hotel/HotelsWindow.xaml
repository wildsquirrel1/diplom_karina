<Window x:Class="hotel.HotelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Отели" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" >
            <StackPanel Margin="10,30,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="280" MaxWidth="720">
                <TextBlock Text="Сотрудник: " FontSize="30" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="28" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <TextBlock Text="Отели" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="50" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0 -5 0 0"/>
            <Image Source="images\icon-icons (2).png" Width="100" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="580 0 0 0"/>
            <TextBlock x:Name="hotelCount" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 0 20 0" MaxWidth="370"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Name="backB" Margin="8,4" Content="✕" Style="{StaticResource CloseWindowButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Click="backB_Click" />

            <Border Grid.Column="1" Background="{StaticResource Brush.Surface}" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="4,2" VerticalAlignment="Center">
                <Grid>
                    <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="60" MinHeight="30" TextChanged="searchTB_TextChanged"/>
                    <TextBlock x:Name="search" Text="Поиск по названию: " Style="{StaticResource searchTB}"/>
                </Grid>
            </Border>

            <ComboBox Grid.Column="2" x:Name="sordCB" Margin="10" MinWidth="160" MaxWidth="360" MinHeight="48" FontSize="26" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="sordCB_SelectionChanged">
                <ComboBoxItem Content="Сначала новые"/>
                <ComboBoxItem Content="От А до Я"/>
                <ComboBoxItem Content="От Я до А"/>
            </ComboBox>

            <ComboBox Grid.Column="3" x:Name="filterCB" Margin="10" MinWidth="120" FontSize="26" MaxWidth="320" MinHeight="48" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="filterCB_SelectionChanged" >
                <ComboBoxItem>Все</ComboBoxItem>
                <ComboBoxItem>1</ComboBoxItem>
                <ComboBoxItem>2</ComboBoxItem>
                <ComboBoxItem>3</ComboBoxItem>
                <ComboBoxItem>4</ComboBoxItem>
                <ComboBoxItem>5</ComboBoxItem>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Отель не найден" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound"/>

        <ScrollViewer Grid.Row="2"
                      x:Name="stack"
                      Margin="12,0,12,8"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="hotelList" Margin="5" HorizontalAlignment="Center"/>
        </ScrollViewer>

        <Button Grid.Row="3" x:Name="addHotel" HorizontalContentAlignment="Center" FontSize="30" Click="addHotel_Click" Content="Добавить" MinWidth="100" MinHeight="40" MaxWidth="400" Margin="10,10,10,10" Padding="5" />
    </Grid>
</Window>
