<Window x:Class="hotel.ServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Услуги" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBlock" x:Key="searchTB">
            <Style.Setters>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="DarkGray"/>
                <Setter Property="Panel.ZIndex" Value="-1"/>
                <Setter Property="Padding" Value="10 0 0 0"/>
            </Style.Setters>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="360"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Grid.Column="0" Margin="30,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Width="320" >
                <TextBlock Text="Сотрудник: " FontSize="25" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="23" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <Image Source="images\icon-icons (2).png" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 350 0" />
            <TextBlock Text="Услуги" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="48" Margin="0,20"/>

            <Button Name="back" Click="back_Click" Width="65" Height="65" Content="X" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 10 20 10" />
        </Grid>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Поиск -->
            <Grid Grid.Column="0" Background="White">
                <TextBox x:Name="searchTB" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                <TextBlock x:Name="search" MaxWidth="900" Text="Поиск по названию: " Style="{StaticResource searchTB}"/>
            </Grid>

            <!-- Сортировка -->
            <ComboBox x:Name="sortBox" Grid.Column="1" FontSize="32" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="sortBox_SelectionChanged">
                <ComboBoxItem Content="Сначала новые"/>
                <ComboBoxItem Content="От А до Я"/>
                <ComboBoxItem Content="От Я до А"/>
            </ComboBox>

            <!-- Фильтр по статусу -->
            <ComboBox x:Name="filterBox" 
              Grid.Column="2" FontSize="32" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="filterBox_SelectionChanged">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Активна"/>
                <ComboBoxItem Content="Не активна"/>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Услуга не найден" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound"/>

        <StackPanel VerticalAlignment="Center" Grid.Row="2" Visibility="Collapsed" Name="stack" >
            <ScrollViewer  Height="600">
                <WrapPanel x:Name="serviceList"/>
            </ScrollViewer>
        </StackPanel>

        <Button Grid.Row="3" Name="addService" Content="Добавить услугу" FontSize="28" HorizontalAlignment="Center" Click="addService_Click"/>
    </Grid>
</Window>
