<Window x:Class="hotel.ServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Услуги" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Grid.Column="0" Margin="30,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="260" MaxWidth="640">
                <TextBlock Text="Сотрудник: " FontSize="25" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="23" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <Image Source="pack://application:,,,/images/icon-icons (2).png" Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 350 0" />
            <TextBlock Text="Услуги" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="48" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0,20"/>

            <Button Name="back" Click="back_Click" Content="✕" Style="{StaticResource CloseWindowButton}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,10,20,10"/>
        </Grid>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Поиск -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Surface}" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="4,2" VerticalAlignment="Center">
                <Grid>
                    <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                    <TextBlock x:Name="search" MaxWidth="900" Text="Поиск по названию: " Style="{StaticResource searchTB}"/>
                </Grid>
            </Border>

            <!-- Сортировка -->
            <ComboBox x:Name="sortBox" Grid.Column="1" FontSize="26" MinHeight="48" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="sortBox_SelectionChanged">
                <ComboBoxItem Content="Сначала новые"/>
                <ComboBoxItem Content="От А до Я"/>
                <ComboBoxItem Content="От Я до А"/>
            </ComboBox>

            <!-- Фильтр по статусу -->
            <ComboBox x:Name="filterBox" 
              Grid.Column="2" FontSize="26" MinHeight="48" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="filterBox_SelectionChanged">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Активна"/>
                <ComboBoxItem Content="Не активна"/>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Услуга не найден" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound"/>

        <StackPanel VerticalAlignment="Center" Grid.Row="2" Visibility="Collapsed" Name="stack" >
            <ScrollViewer  Height="600">
                <WrapPanel x:Name="serviceList"/>
            </ScrollViewer>
        </StackPanel>

        <Button Grid.Row="3" Name="addService" Content="Добавить услугу" FontSize="28" HorizontalAlignment="Center" Click="addService_Click"/>
    </Grid>
</Window>
