<Window x:Class="hotel.HeadHotelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Главный менеджер по отелям" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="C:\Users\Пользователь\source\repos\hotel\hotel\images\local-hotel_118960.png">
    <Window.Resources>
        <!-- Стиль для всех кнопок -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="360"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="Margin" Value="0,90,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для заголовка -->
        <Style TargetType="TextBlock" x:Key="HotelTitle">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,40,0,30"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="30,30,0,0" VerticalAlignment="Top">
            <TextBlock Text="Сотрудник: " FontSize="30" Foreground="Black" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="28" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Название отеля -->
            <TextBlock Grid.Row="0" HorizontalAlignment="Center" Margin="0,60,0,50">
                <Run Text="Простой" FontSize="52" FontWeight="Bold" Foreground="#8A6DF7"/>
                <Run Text="Комфорт" FontSize="52" FontWeight="Bold" Foreground="Black"/>
            </TextBlock>
            <Image Source="C:\Users\Пользователь\source\repos\hotel\hotel\images\icon-icons (2).png" Width="150" VerticalAlignment="Center" HorizontalAlignment="Left"/>

            <Button Grid.Row="1" Name="hotels" Content="Отели" Click="hotels_Click"/>
            <Button Grid.Row="2" Name="reports" Content="Отчеты" Click="reports_Click"/>
            <Button Grid.Row="3" Name="employees" Content="Сотрудники" Click="employees_Click" />
        </Grid>

        <Button Grid.Column="2" 
                Content="X" 
                FontSize="22" 
                FontWeight="Bold"
                Width="40" Height="40" 
                Background="#8A6DF7" 
                Foreground="White"
                BorderBrush="Transparent"
                Cursor="Hand"
                VerticalAlignment="Top" 
                HorizontalAlignment="Right" 
                Margin="0,30,30,0"
                Name="exit"
                Click="exit_Click"/>
    </Grid>
</Window>
