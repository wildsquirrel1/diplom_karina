<Window x:Class="hotel.HeadHotelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Главный менеджер по отелям" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="30,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" MinWidth="280" MaxWidth="720">
            <TextBlock Text="Сотрудник: " FontSize="30" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="28" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Название отеля -->
            <TextBlock Grid.Row="0" HorizontalAlignment="Center" Margin="0,60,0,50">
                <Run Text="Простой" FontSize="52" FontWeight="Bold" Foreground="{StaticResource Brush.Accent}"/>
                <Run Text="Комфорт" FontSize="52" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}"/>
            </TextBlock>
            <Image Source="images\icon-icons (2).png" Width="150" VerticalAlignment="Center" HorizontalAlignment="Left"/>

            <Button Grid.Row="1" Name="hotels" Content="Отели" Click="hotels_Click" Style="{StaticResource NavMenuButton}"/>
            <Button Grid.Row="2" Name="reports" Content="Отчеты" Click="reports_Click" Style="{StaticResource NavMenuButton}"/>
            <Button Grid.Row="3" Name="employees" Content="Сотрудники" Click="employees_Click" Style="{StaticResource NavMenuButton}" />
        </Grid>

        <Button Grid.Column="2" Content="✕" Style="{StaticResource CloseWindowButton}" Margin="0,30,30,0" Name="exit" Click="exit_Click"/>
    </Grid>
</Window>
