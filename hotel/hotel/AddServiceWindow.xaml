<Window x:Class="hotel.AddServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Style="{StaticResource DialogWindow}"
        Title="Добавление услуги" Height="680" MinHeight="520"
        Width="640" MinWidth="560" MaxWidth="800"
        WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200" MaxWidth="360"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Сотрудник: " Style="{StaticResource DialogEmployeeName}" Name="emplName" TextWrapping="Wrap"/>
                    <TextBlock Text="Роль: " Style="{StaticResource DialogEmployeeRole}" Name="emplRole" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Добавление услуги" Style="{StaticResource FormPageTitle}"/>
                <Button Grid.Column="2" x:Name="back" Content="✕" Style="{StaticResource CloseWindowButton}"
                        VerticalAlignment="Center" Click="back_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Style="{StaticResource DialogFormBody}">
            <Border Style="{StaticResource FormCard}" Margin="0" MaxWidth="560" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Параметры услуги" Style="{StaticResource FormSectionTitle}"/>
                    <TextBlock Text="Название" Style="{StaticResource FormFieldLabel}"/>
                    <TextBox x:Name="nameTB" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                             PreviewTextInput="nameTB_PreviewTextInput"/>
                    <TextBlock Text="Описание" Style="{StaticResource FormFieldLabel}"/>
                    <TextBox x:Name="descriptionTB" Style="{StaticResource FormTextBoxMultiline}" Margin="0,0,0,14"
                             PreviewTextInput="descriptionTB_PreviewTextInput"/>
                    <TextBlock Text="Цена (руб.)" Style="{StaticResource FormFieldLabel}"/>
                    <TextBox x:Name="priceTB" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                             PreviewTextInput="priceTB_PreviewTextInput"/>
                    <TextBlock Text="Статус" Style="{StaticResource FormFieldLabel}"/>
                    <ComboBox x:Name="statusCB" Style="{StaticResource FormComboBox}"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DialogActionBar}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="back_Click" Margin="0,0,12,0"/>
                <Button Name="addB" Content="Добавить" Style="{StaticResource DialogPrimaryButton}" Click="addB_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
