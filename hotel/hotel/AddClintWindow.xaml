<Window x:Class="hotel.AddClintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Style="{StaticResource DialogWindow}"
        Title="Добавление клиента" Height="820" MinHeight="640"
        Width="1100" MinWidth="920" MaxWidth="1280"
        WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200" MaxWidth="360"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Сотрудник: " Style="{StaticResource DialogEmployeeName}" Name="emplName" TextWrapping="Wrap"/>
                    <TextBlock Text="Роль: " Style="{StaticResource DialogEmployeeRole}" Name="emplRole" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Клиент и гости" Style="{StaticResource FormPageTitle}"/>
                <Button Grid.Column="2" x:Name="exit" Content="✕" Style="{StaticResource CloseWindowButton}"
                        VerticalAlignment="Center" Click="exit_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Style="{StaticResource DialogFormBody}">
            <Grid MaxWidth="1040" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Новый клиент" Style="{StaticResource FormSectionTitle}"/>
                        <TextBlock Text="Фамилия, имя, отчество" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Name="fioBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                                 MaxLength="153" PreviewTextInput="fioBox_PreviewTextInput"/>
                        <TextBlock Text="Дата рождения" Style="{StaticResource FormFieldLabel}"/>
                        <DatePicker Name="datebirth" Style="{StaticResource FormDatePicker}" Margin="0,0,0,14"
                                    SelectedDate="{Binding Datebirth, Mode=TwoWay}" PreviewTextInput="datebirth_PreviewTextInput"/>
                        <TextBlock Text="Серия и номер паспорта" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Name="passportBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                                 MaxLength="10" KeyDown="passportBox_KeyDown"/>
                        <TextBlock Text="Электронная почта" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Name="emailBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14" MaxLength="100"/>
                        <TextBlock Text="Пароль" Style="{StaticResource FormFieldLabel}"/>
                        <PasswordBox Name="passwordBox" Style="{StaticResource FormPasswordBox}" MaxLength="10"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource FormColumnDivider}"/>

                <Border Grid.Column="2" Style="{StaticResource FormCard}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Гость" Style="{StaticResource FormSectionTitle}"/>
                        <TextBlock Text="Фамилия, имя, отчество" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Name="fioBoxGuest" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                                 MaxLength="153" PreviewTextInput="fioBoxGuest_PreviewTextInput"/>
                        <TextBlock Text="Тип документа" Style="{StaticResource FormFieldLabel}"/>
                        <ComboBox Name="docTypeCombo" Style="{StaticResource FormComboBox}" Margin="0,0,0,14" SelectedIndex="0">
                            <ComboBoxItem>Паспорт</ComboBoxItem>
                            <ComboBoxItem>Св. о рождении</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="Номер документа" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Name="docNumber" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"
                                 MaxLength="10" KeyDown="docNumber_KeyDown"/>
                        <Button Name="addGuestButton" Content="Добавить гостя" Style="{StaticResource FormInlineButton}"
                                HorizontalAlignment="Left" Click="addGuestButton_Click"/>
                        <TextBlock Name="countGuests" Text="Кол-во гостей: 0" Margin="0,14,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}" FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DialogActionBar}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="exit_Click" Margin="0,0,12,0"/>
                <Button x:Name="doneButton" Content="Готово" Style="{StaticResource DialogPrimaryButton}" Click="doneButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
