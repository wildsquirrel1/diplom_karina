<Window x:Class="hotel.ReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Отзывы" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="400*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" >
            <StackPanel Margin="10,30,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="260" MaxWidth="720">
                <TextBlock Text="Сотрудник: " FontSize="30" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
                <TextBlock Text="Роль: " FontSize="28" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>
            <TextBlock Text="Отзывы" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="50" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0 -5 0 0"/>
            <Image Source="images\icon-icons (2).png" Width="100" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="580 0 0 0"/>
            <TextBlock x:Name="hotelCount" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 0 20 0" MaxWidth="370"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="890"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Name="backB" Margin="8,4" Content="✕" Style="{StaticResource CloseWindowButton}" VerticalAlignment="Center" Click="backB_Click" />

            <Border Grid.Column="1" Background="{StaticResource Brush.Surface}" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="4,2" VerticalAlignment="Center">
                <Grid>
                    <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                    <TextBlock x:Name="search" MaxWidth="900" Text="Поиск по названию: " Style="{StaticResource searchTB}"/>
                </Grid>
            </Border>

            <ComboBox Grid.Column="2" x:Name="sordCB" Margin="10" MinWidth="220" MaxWidth="420" MinHeight="48" FontSize="22" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="sordCB_SelectionChanged">
                <ComboBoxItem Content="По дате: старые сверху"/>
                <ComboBoxItem Content="По дате: новые сверху"/>
                <ComboBoxItem Content="По звёздам: выше сначала"/>
                <ComboBoxItem Content="По звёздам: ниже сначала"/>
            </ComboBox>

            <ComboBox Grid.Column="3" x:Name="filterCB" Margin="10" MinWidth="120" FontSize="26" MaxWidth="320" MinHeight="48" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="filterCB_SelectionChanged" >
                <ComboBoxItem>Все</ComboBoxItem>
                <ComboBoxItem>1</ComboBoxItem>
                <ComboBoxItem>2</ComboBoxItem>
                <ComboBoxItem>3</ComboBoxItem>
                <ComboBoxItem>4</ComboBoxItem>
                <ComboBoxItem>5</ComboBoxItem>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Отзывы не найдены" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound"/>

        <StackPanel VerticalAlignment="Top" Grid.Row="2" Visibility="Collapsed" Name="stack" Margin="0,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel Name="ReviewsPanel"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
