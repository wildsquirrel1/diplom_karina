<Window x:Class="hotel.AddHotelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Style="{StaticResource DialogWindow}"
        Title="Добавление" Height="950" MinHeight="730" Width="1500" MinWidth="900"
        WindowState="Maximized" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBar}">
            <Grid MinHeight="72">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" MaxWidth="400"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Сотрудник: " Style="{StaticResource DialogEmployeeName}" Name="emplName" TextWrapping="Wrap"/>
                    <TextBlock Text="Роль: " Style="{StaticResource DialogEmployeeRole}" Name="emplRole" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="images\icon-icons (2).png" Width="64" Height="64" Margin="0,0,12,0" Opacity="0.95"/>
                    <TextBlock Text="Добавление отеля" Style="{StaticResource FormPageTitle}"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="back" Content="✕" Style="{StaticResource CloseWindowButton}"
                        VerticalAlignment="Center" Click="back_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320" MaxWidth="480"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource FormCard}">
                    <Grid>
                        <Image Source="{Binding Photo}" x:Name="photoDisplay" Stretch="Uniform" MaxHeight="420"/>
                        <Button Name="loadPhoto" Click="loadPhoto_Click" Content="Загрузить фотографию"
                                Style="{StaticResource FormInlineButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource FormCard}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Контакты и документы" Style="{StaticResource FormSectionTitle}"/>
                            <TextBlock Text="Название:" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox x:Name="nameT" Style="{StaticResource FormTextBox}" Margin="0,0,0,12"
                                     PreviewTextInput="nameT_PreviewTextInput" MaxLength="100" IsEnabled="False"/>
                            <TextBlock Text="Номер телефона:" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox x:Name="phontT" Style="{StaticResource FormTextBox}" Margin="0,0,0,12"
                                     KeyDown="phontT_KeyDown" MaxLength="11"/>
                            <TextBlock Text="Электронная почта:" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox x:Name="emailT" Style="{StaticResource FormTextBox}" Margin="0,0,0,12" MaxHeight="120"/>
                            <TextBlock Text="Договор:" Style="{StaticResource FormFieldLabel}"/>
                            <Grid Margin="0,0,0,12">
                                <Button x:Name="pdfFormatDocument" Style="{StaticResource FormInlineButton}"
                                        HorizontalAlignment="Left" Content="Загрузить PDF файл" Click="pdfFormatDocument_Click"/>
                                <TextBlock x:Name="nameOfDocument" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}" FontSize="14" TextWrapping="Wrap" MaxWidth="280"/>
                            </Grid>
                            <TextBlock Text="Адрес:" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox x:Name="address" Style="{StaticResource FormTextBox}" IsEnabled="False" MaxLength="150"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Text="Карта" Style="{StaticResource FormSectionTitle}"/>
                            <Border CornerRadius="10" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" ClipToBounds="True">
                                <wv2:WebView2 x:Name="YandexMapWebView" MinHeight="360" Height="420"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DialogActionBar}">
            <Button x:Name="addB" Click="addB_Click" Content="Добавить" Style="{StaticResource DialogPrimaryButton}"
                    HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
