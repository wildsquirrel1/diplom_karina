<Window x:Class="hotel.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Клиенты" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Клиенты" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="48" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0,20"/>

        <StackPanel Grid.Row="0" Margin="30,30,0,0" VerticalAlignment="Top">
            <TextBlock Text="Сотрудник: " FontSize="30" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap"/>
            <TextBlock Text="Роль: " FontSize="28" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <Image Source="images\icon-icons (2).png" Height="100" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 280 0"/>

        <Button Grid.Row="0" Name="back" Click="back_Click" Content="✕" Style="{StaticResource CloseWindowButton}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,10,20,10"/>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Brush.Surface}" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="4,2" VerticalAlignment="Center">
                <Grid>
                <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="60" MinHeight="30" MaxWidth="900" TextChanged="searchTB_TextChanged"/>
                <TextBlock x:Name="search" MaxWidth="900" Text="Поиск по фио: " Style="{StaticResource searchTB}"/>
                </Grid>
            </Border>


            <ComboBox x:Name="sortBox" Grid.Column="1" FontSize="26" MinHeight="48" SelectedIndex="0" Margin="20,0,0,0" SelectionChanged="sortBox_SelectionChanged">
                <ComboBoxItem Content="Сначала новые"/>
                <ComboBoxItem Content="От А до Я"/>
                <ComboBoxItem Content="От Я до А"/>
            </ComboBox>

            <ComboBox x:Name="filterBox" Grid.Column="2" SelectedIndex="0" SelectionChanged="filterBox_SelectionChanged" Margin="10,0,0,0" FontSize="26" MinHeight="48">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Текущие"/>
                <ComboBoxItem Content="Завершенные"/>
            </ComboBox>
        </Grid>

        <Label Grid.Row="2" Content="Клиент не найден" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" Visibility="Visible" Name="notfound" Grid.RowSpan="2"/>

        <ScrollViewer Grid.Row="2" Margin="30,10" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" x:Name="scrollViewer">
            <WrapPanel x:Name="clientsPanel"/>
        </ScrollViewer>

    </Grid>
</Window>
