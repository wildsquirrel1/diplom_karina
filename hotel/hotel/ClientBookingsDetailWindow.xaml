<Window x:Class="hotel.ClientBookingsDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Детали бронией" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MinHeight="88">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260" MaxWidth="480"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="16,12,8,0" VerticalAlignment="Center">
                <TextBlock Text="Сотрудник: " FontSize="22" Foreground="{StaticResource Brush.TextPrimary}" Name="emplName" TextWrapping="Wrap" />
                <TextBlock Text="Роль: " FontSize="20" Foreground="{StaticResource Brush.TextSecondary}" Name="emplRole" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="images\icon-icons (2).png" Height="72" Width="72" Margin="0,0,12,0" VerticalAlignment="Center" Opacity="0.95"/>
                <TextBlock x:Name="clientHeader" VerticalAlignment="Center" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="720"/>
            </StackPanel>

            <Button Grid.Column="2" Name="back" Click="back_Click" Width="56" Height="56" Content="✕" FontSize="28" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,20,0" Panel.ZIndex="100" Style="{StaticResource CloseWindowButton}" />
        </Grid>

        <Border Grid.Row="1" Margin="24,8,24,0" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Background="{StaticResource Brush.Surface}" Padding="6,4">
            <Grid>
                <TextBox x:Name="searchTB" Style="{StaticResource SearchOverlayTextBox}" MaxHeight="56" MinHeight="36" TextChanged="searchTB_TextChanged"/>
                <TextBlock x:Name="search" Text="Поиск по дате заезда (ДД.ММ.ГГГГ): " Style="{StaticResource searchTB}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0 15 0 0">
            <StackPanel x:Name="bookingsList"/>
        </ScrollViewer>
    </Grid>
</Window>
