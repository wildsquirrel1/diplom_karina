<Window x:Class="hotel.ClientBookingsDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel"
        mc:Ignorable="d"
        Title="Детали бронией" Height="950" MinHeight="730" MaxHeight="1000"  Width="1500" MinWidth="900" MaxWidth="1600" WindowState="Maximized" FontSize="40" WindowStartupLocation="CenterScreen" Icon="images\local-hotel_118960.png">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBlock" x:Key="searchTB">
            <Style.Setters>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="DarkGray"/>
                <Setter Property="Panel.ZIndex" Value="-1"/>
                <Setter Property="Padding" Value="10 0 0 0"/>
            </Style.Setters>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="34"/>
            <!-- Увеличен шрифт -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A6DF7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <!-- Чуть шире -->
            <Setter Property="Height" Value="60"/>
            <!-- Выше -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="clientHeader" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" Margin="0,20"/>

        <Image Source="images\icon-icons (2).png" Height="100" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="900 0 0 0"/>

        <Button Grid.Row="0" Name="back" Click="back_Click" Width="65" Height="65" Content="X" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 10 20 10" Panel.ZIndex="100" />

        <StackPanel Grid.Row="0" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300">
            <TextBlock Text="Сотрудник: " FontSize="26" Foreground="Black" Name="emplName" TextWrapping="Wrap" />
            <TextBlock Text="Роль: " FontSize="24" Foreground="Black" Name="emplRole" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 15 0 0">
            <StackPanel x:Name="bookingsList"/>
        </ScrollViewer>
    </Grid>
</Window>
