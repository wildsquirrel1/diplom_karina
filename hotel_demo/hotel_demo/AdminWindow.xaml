<Window x:Class="hotel_demo.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel_demo"
        mc:Ignorable="d"
        Title="Администратор" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="6*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Height="30" Width="30" Name="backBtn"
                    Content="X" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="backBtn_Click" />
            
            <TextBox Grid.Column="1" Name="searchTB" Height="30" Width="530" TextChanged="searchTB_TextChanged" />

            <ComboBox Name="sortCB" Grid.Column="2" Height="30" Width="110" FontSize="14" SelectedIndex="0"  SelectionChanged="sortCB_SelectionChanged" >
                <TextBlock>От А до Я</TextBlock>
                <TextBlock>От Я до А</TextBlock>
            </ComboBox>

            <ComboBox Name="filterCB" Grid.Column="3" Height="30" Width="110" SelectedIndex="0" FontSize="14" SelectionChanged="filterCB_SelectionChanged" >
                <TextBlock>Все</TextBlock>
            </ComboBox>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid x:Name="EmployeeDG" IsReadOnly="True" Margin="10" AutoGenerateColumns="False"
                      SelectionChanged="EmployeeDG_SelectionChanged" CanUserAddRows="False" FontSize="15" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding Lastname}"/>
                    <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding Birth}"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Email}"/>
                    <DataGridTextColumn Header="Пароль" Binding="{Binding Password}"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}"/>
                    <DataGridTextColumn Header="Заблокирован" Binding="{Binding Isblocked}" x:Name="isblockedItem"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="10" Content="Добавить" Name="addBtn" Click="addBtn_Click" />
            <Button Grid.Column="1" Margin="10" Content="Редактировать" Name="editBtn" Click="editBtn_Click" />
            <Button Grid.Column="2" Margin="10" Content="Снять блокировку" Name="statusEdit" Click="statusEdit_Click"  />
        </Grid>
    </Grid>
</Window>
