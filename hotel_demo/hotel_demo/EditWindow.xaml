<Window x:Class="hotel_demo.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hotel_demo"
        mc:Ignorable="d"
        Title="Редактирование" Height="600" Width="350" FontSize="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Редактирование" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Grid.Row="0" />
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Фамилия:"  VerticalAlignment="Bottom" Grid.Row="0"/>
            <TextBox Grid.Row="1"  HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Name="lastnameTB" MaxLength="50" PreviewTextInput="lastnameTB_PreviewTextInput"  />
        </Grid>
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Имя:"  VerticalAlignment="Bottom" Grid.Row="0"/>
            <TextBox Grid.Row="1"  HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Name="nameTB" MaxLength="50" PreviewTextInput="nameTB_PreviewTextInput"   />
        </Grid>
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Отчество:"  VerticalAlignment="Bottom" Grid.Row="0"/>
            <TextBox Grid.Row="1" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Name="patronymicTB" MaxLength="50" PreviewTextInput="patronymicTB_PreviewTextInput"  />
        </Grid>
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Электронная почта:" VerticalAlignment="Bottom" Grid.Row="0"/>
            <TextBox Grid.Row="1" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Name="emailTB" MaxLength="50"   />
        </Grid>
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Пароль:"  VerticalAlignment="Bottom" Grid.Row="0"/>
            <TextBox Grid.Row="1"  HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Name="passwordTB" MaxLength="50"   />
        </Grid>

        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Дата рождения:"  VerticalAlignment="Bottom" Grid.Row="0"  />
            <DatePicker Name="birth" Grid.Row="1" PreviewTextInput="birth_PreviewTextInput" VerticalContentAlignment="Center" />
        </Grid>

        <Grid Grid.Row="7" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="106*"/>
                <ColumnDefinition Width="69*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Статус:" VerticalAlignment="Bottom" Grid.Row="0" Grid.ColumnSpan="2"/>
            <ComboBox x:Name="idstatus" Grid.ColumnSpan="2" Margin="0,32,0,0" Grid.RowSpan="2" >
                <TextBlock>Заблокирован</TextBlock>
                <TextBlock>Не заблокирован</TextBlock>
            </ComboBox>
        </Grid>

        <Button Grid.Row="8" Name="editB" Content="Редактировать" Margin="10 15" Click="editB_Click" />
    </Grid>
</Window>
